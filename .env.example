# Optional path to the tossctl executable.
# Defaults to the first tossctl found in PATH.
QUANT_TOSSCTL=

# Optional future data providers. Leave unset until the provider is enabled.
ALPHA_VANTAGE_API_KEY=
FRED_API_KEY=
OPENDART_API_KEY=
POLYGON_API_KEY=
NASDAQ_DATA_LINK_API_KEY=

# Optional broker API credentials. Do not enable write/trading mutations by default.
KIS_APP_KEY=
KIS_APP_SECRET=
